{
  "name": "plant-doctor-app",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:web": "EXPO_PUBLIC_API_BASE_URL=https://plant-doctor-server-2cdy.onrender.com expo export -p web --clear",
    "deploy": "npm run build:web && touch dist/.nojekyll && gh-pages -d dist --dotfiles"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "expo": "^54.0.0",
    "expo-asset": "~12.0.13",
    "expo-image-picker": "~17.0.11",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.1.0",
    "gh-pages": "^6.3.0",
    "typescript": "^5.3.3"
  }
}
